rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /staff/{staffId} {
      allow read: if request.auth != null;
      allow create: if isAdmin() && hasValidStaffData();
      allow update: if isAdmin() || isSelf(staffId);
      allow delete: if isAdmin();
    }
    
    match /stores/{storeId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isSelf(staffId) {
      return request.auth != null && staffId == request.auth.uid;
    }
    
    function hasValidStaffData() {
      return request.resource.data.name is string &&
             request.resource.data.email is string &&
             request.resource.data.role in ['admin', 'manager', 'staff'] &&
             request.resource.data.status in ['active', 'inactive'];
    }
  }
}